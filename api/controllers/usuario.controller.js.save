const db = require('../db');
const bcrypt = require('bcryptjs');


exports.listar = (req, res) => {
  db.query('SELECT * FROM usuarios', (err, results) => {
    if (err) return res.status(500).json({ erro: 'Erro ao buscar usuários' });
    res.json(results);
  });
};

exports.buscar = (req, res) => {
  db.query('SELECT * FROM usuarios WHERE id = ?', [req.params.id], (err, results) => {
    if (err) return res.status(500).json({ erro: 'Erro ao buscar usuário' });
    if (!results.length) return res.status(404).json({ erro: 'Usuário não encontrado' });
    res.json(results[0]);
  });
};

exports.criar = async (req, res) => {
   
  const { usuUsuario, usuNome, usuEmail, usuSenha } = req.body;
  const usuSenhaHash = await bcrypt.hash(usuSenha, 10);
 
  db.query('INSERT INTO usuarios (usuUsuario, usuNome, usuEmail, usuSenha) VALUES (?, ?, ?, ?)', [usuUsuario, usuNome, usuEmail, usuSenhaHash], (err, result) => {
    console.log(err)
    if (err) return res.status(500).json({ erro: 'Erro ao criar usuário' });
    res.status(201).json({ id: result.insertId, usuNome, usuEmail });
  });
};

exports.atualizar = (req, res) => {
  const { usuNome, usuEmail } = req.body;
  db.query('UPDATE users SET usuNome = ?, usuEmail = ? WHERE id = ?', [usuNome, usuEmail, req.params.id], (err, result) => {
    if (err) return res.status(500).json({ erro: 'Erro ao atualizar usuário' });
    if (!result.affectedRows) return res.status(404).json({ erro: 'Usuário não encontrado' });
    res.json({ id: req.params.id, usuNome, usuEmail });
  });
};

exports.deletar = (req, res) => {
  db.query('DELETE FROM users WHERE id = ?', [req.params.id], (err, result) => {
    if (err) return res.status(500).json({ erro: 'Erro ao deletar usuário' });
    if (!result.affectedRows) return res.status(404).json({ erro: 'Usuário não encontrado' });
    res.status(204).send();
  });
};

